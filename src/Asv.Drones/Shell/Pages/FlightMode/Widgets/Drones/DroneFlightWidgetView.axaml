<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:drones="clr-namespace:Asv.Drones"
    mc:Ignorable="d"
    d:DesignHeight="1000"
    x:Class="Asv.Drones.DroneFlightWidgetView"
    x:DataType="drones:DroneFlightWidgetViewModel"
>
    <Design.DataContext>
        <drones:DroneFlightWidgetViewModel />
    </Design.DataContext>

    <ItemsControl ItemsSource="{Binding DashboardWidgetsView}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel ItemSpacing="4" LineSpacing="4" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <ContentControl Margin="5" Content="{Binding}" />
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
