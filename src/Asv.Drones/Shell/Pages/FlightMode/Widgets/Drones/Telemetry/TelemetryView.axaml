<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:drones="clr-namespace:Asv.Drones"
    mc:Ignorable="d"
    d:DesignHeight="300"
    x:Class="Asv.Drones.TelemetryView"
    x:DataType="drones:TelemetryViewModel"
>
    <Design.DataContext>
        <drones:TelemetryViewModel />
    </Design.DataContext>

    <WrapPanel
        ItemSpacing="4"
        LineSpacing="4"
        Orientation="Horizontal"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
    >
        <drones:BatteryUavIndicator DataContext="{CompiledBinding BatteryUavIndicator}" />
        <drones:AltitudeUavIndicator DataContext="{CompiledBinding AltitudeUavIndicator}" />
        <drones:VelocityUavIndicator DataContext="{CompiledBinding VelocityUavIndicator}" />
        <drones:AngleUavRttIndicator DataContext="{CompiledBinding AngleUavRttIndicator}" />
    </WrapPanel>
</UserControl>
