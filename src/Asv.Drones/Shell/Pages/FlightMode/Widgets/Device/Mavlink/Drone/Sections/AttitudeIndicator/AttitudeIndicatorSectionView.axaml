<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:drones="clr-namespace:Asv.Drones"
    mc:Ignorable="d"
    x:Class="Asv.Drones.AttitudeIndicatorSectionView"
    x:DataType="drones:AttitudeIndicatorSectionViewModel"
>
    <WrapPanel Orientation="Horizontal" ItemWidth="220">
        <Viewbox>
            <drones:UavAngleIndicator
                RollAngle="{Binding Roll.Value}"
                PitchAngle="{Binding Pitch.Value}"
                CornerRadius="500"
            />
        </Viewbox>
        <Viewbox>
            <drones:CompassUavIndicator
                Heading="{CompiledBinding Heading.Value}"
                HomeAzimuth="{CompiledBinding HomeAzimuth.Value}"
            />
        </Viewbox>
    </WrapPanel>
</UserControl>
