<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:geoMap="clr-namespace:Asv.Avalonia.GeoMap;assembly=Asv.Avalonia.GeoMap"
             xmlns:avalonia="clr-namespace:Asv.Avalonia;assembly=Asv.Avalonia"
             xmlns:drones="clr-namespace:Asv.Drones"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Asv.Drones.PlaningPageView"
             x:DataType="drones:PlaningPageViewModel"
>
    <Design.DataContext>
        <drones:PlaningPageViewModel />
    </Design.DataContext>
    <Panel>
        <geoMap:MapView x:Name="PART_Map" DataContext="{CompiledBinding Map}" />
        <ItemsControl ItemsSource="{Binding WidgetsView}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <avalonia:WorkspacePanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <avalonia:WorkspaceItem
                        Content="{Binding}" 
                        Margin="0"
                    />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <geoMap:MapCompass
            Rotation="{Binding Map.Rotation.Value}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="8"
            GestureSurface="{Binding #PART_Map}"
            TouchpadRotationSensitivity="1"
        />
    </Panel>
</UserControl>
