<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:drones="clr-namespace:Asv.Drones"
>
    <Design.PreviewWith>
        <UniformGrid Rows="2" Columns="2">
            <drones:CompassUavIndicator Width="300" Height="300" Heading="10" HomeAzimuth="300" />
            <drones:CompassUavIndicator Width="300" Height="300" Heading="210" HomeAzimuth="60" />
            <drones:CompassUavIndicator Width="300" Height="300" Heading="359" HomeAzimuth="1" />
            <drones:CompassUavIndicator Width="300" Height="300" Heading="-45" HomeAzimuth="NaN" />
        </UniformGrid>
    </Design.PreviewWith>

    <Style Selector="drones|CompassUavIndicator">
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="300" />
        <Setter Property="Template">
            <ControlTemplate>
                <Viewbox>
                    <Canvas Width="300" Height="300">
                        <Ellipse
                            Canvas.Left="8"
                            Canvas.Top="8"
                            Width="284"
                            Height="284"
                            Fill="#9bd2e0"
                            Stroke="#f4fbff"
                            StrokeThickness="3"
                        />
                        <Ellipse
                            Canvas.Left="18"
                            Canvas.Top="18"
                            Width="264"
                            Height="264"
                            Fill="#78c3d5"
                            Opacity="0.55"
                        />
                        <ItemsControl
                            Width="300"
                            Height="300"
                            ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=CompassItems}"
                        >
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="300" Height="300" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="drones:CompassScaleItem">
                                    <Canvas Width="300" Height="300">
                                        <Line
                                            StartPoint="{CompiledBinding TickStart}"
                                            EndPoint="{CompiledBinding TickEnd}"
                                            Stroke="#f4fbff"
                                            StrokeThickness="{CompiledBinding TickWidth}"
                                            StrokeLineCap="Round"
                                        />
                                        <TextBlock
                                            Canvas.Left="{CompiledBinding LabelLeft}"
                                            Canvas.Top="{CompiledBinding LabelTop}"
                                            Width="44"
                                            Height="24"
                                            IsVisible="{CompiledBinding HasTitle}"
                                            Text="{CompiledBinding Title}"
                                            Foreground="#f4fbff"
                                            FontWeight="SemiBold"
                                            FontSize="18"
                                            TextAlignment="Center"
                                        />
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Path
                            Fill="#ff3d00"
                            Stroke="#f4fbff"
                            StrokeThickness="1.5"
                            Data="M150,82 L147,10 L153,10 Z"
                        />
                        <Canvas Width="300" Height="300" RenderTransformOrigin="50%,50%">
                            <Canvas.RenderTransform>
                                <RotateTransform Angle="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HomeMarkerRotation}" />
                            </Canvas.RenderTransform>
                            <Path
                                Fill="#ff8a00"
                                Stroke="#f4fbff"
                                StrokeThickness="2"
                                Data="M150,42 L140,23 L160,23 Z"
                            />
                        </Canvas>

                        <Ellipse
                            Canvas.Left="88"
                            Canvas.Top="88"
                            Width="124"
                            Height="124"
                            Fill="#f7fbff"
                            Stroke="#1682ad"
                            StrokeThickness="3"
                        />
                        <TextBlock
                            Canvas.Left="94"
                            Canvas.Top="125"
                            Width="112"
                            Height="52"
                            Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HeadingText}"
                            Foreground="#4c95b4"
                            FontSize="44"
                            FontWeight="Regular"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                        />
                    </Canvas>
                </Viewbox>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
